+static bool IsMiniloongInternalPanel()
+{
+  FILE* f = std::fopen("/home/ark/.config/.DEVICE", "r");
+  if (!f)
+    return false;
+
+  char device[128] = {};
+  const bool read_device = std::fgets(device, sizeof(device), f) != nullptr;
+  std::fclose(f);
+
+  if (!read_device || (std::strstr(device, "miniloong") == nullptr &&
+                       std::strstr(device, "MINILOONG") == nullptr &&
+                       std::strstr(device, "Miniloong") == nullptr))
+  {
+    return false;
+  }
+
+  // Do not apply the internal LCD rotation when HDMI is connected.
+  // Important: do not use strstr(status, "connected"), because "disconnected"
+  // also contains the substring "connected".
+  const char* hdmi_paths[] = {
+      "/sys/class/drm/card0-HDMI-A-1/status",
+      "/sys/class/drm/card1-HDMI-A-1/status",
+  };
+
+  for (const char* path : hdmi_paths)
+  {
+    FILE* h = std::fopen(path, "r");
+    if (!h)
+      continue;
+
+    char status[32] = {};
+    const bool read_status = std::fgets(status, sizeof(status), h) != nullptr;
+    std::fclose(h);
+
+    if (read_status && std::strncmp(status, "connected", 9) == 0)
+      return false;
+  }
+
+  return true;
+}
