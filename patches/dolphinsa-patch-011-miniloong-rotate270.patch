+static bool IsMiniloongInternalPanel()
+{
+  FILE* f = std::fopen("/home/ark/.config/.DEVICE", "r");
+  if (!f)
+    return false;
+
+  char device[128] = {};
+  const bool read_device = std::fgets(device, sizeof(device), f) != nullptr;
+  std::fclose(f);
+
+  if (!read_device || std::strstr(device, "miniloong") == nullptr)
+    return false;
